# ================================
# Template Bot — Variáveis de Ambiente
# ================================

# Porta do servidor Express
PORT=3000

# Groq AI (LLM + Whisper)
GROQ_API_KEY=sua_groq_api_key

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution.up.railway.app
EVOLUTION_GLOBAL_APIKEY=sua_chave_global
INSTANCE_NAME=nome-da-instancia

# Telegram (Sócio Digital) — opcional
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Segurança do Webhook — opcional
WEBHOOK_SECRET=

# LLM Tuning — opcional (defaults sensatos já configurados)
# LLM_MODEL=llama-3.1-8b-instant
# LLM_TEMPERATURE_ATTENDANT=0.8
# LLM_TEMPERATURE_PARTNER=0.85
# LLM_MAX_TOKENS_ATTENDANT=150
# LLM_MAX_TOKENS_PARTNER=200
